{
  "name": "hls-react-player",
  "version": "0.5.1",
  "description": "React video player for MP4, HLS, and DASH",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sonu-daryani/react-stream-player.git"
  },
  "homepage": "https://github.com/sonu-daryani/react-stream-player#readme",
  "bugs": {
    "url": "https://github.com/sonu-daryani/react-stream-player/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/index.css",
  "sideEffects": ["**/*.css"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "demo:install": "npm install --prefix demo",
    "demo:dev": "npm run dev --prefix demo",
    "demo:build": "npm run build --prefix demo"
  },
  "dependencies": {
    "dashjs": "^5.0.3",
    "hls.js": "^1.6.13",
    "lucide-react": "^0.552.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.38.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
